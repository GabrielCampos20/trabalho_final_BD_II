{
  "mongodb": {
    "uri": "mongodb://localhost:27017/",
    "database": "bd2_experimentos",
    "collection": "usuarios"
  },
  "dataset": {
    "tamanho_gb": 0.1,
    "locale": "pt_BR",
    "batch_size": 50000
  },
  "experimentos": {
    "repeticoes": 10,
    "seed": 42,
    "filtros": {
      "modo": "automatico",
      "manual": {
        "estado": "SP",
        "ativo": true,
        "salario_min": 5000.0,
        "salario_max": 5100.0,
        "ano": 2020,
        "profissao": "Desenvolvedor"
      }
    }
  },
  "graficos": {
    "output_dir": "resultados",
    "dpi": 400,
    "formato": "png"
  }
}